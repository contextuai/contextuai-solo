{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "ContextuAI Solo",
  "version": "1.0.0",
  "identifier": "com.contextuai.solo",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ContextuAI Solo",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "sidecar"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "currentUser",
        "installerHooks": "nsis-hooks.nsh"
      }
    }
  },
  "plugins": {
    "shell": { "open": true },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc1RTNCOTU5QUQ1NURCQUYKUldTdjIxV3RXYm5qZGQvaEFTVjZnV1JFd1NiTkxxbUtPUHh0d0FGa2VwdnkxL3A0cEZFQWJ3dUkK",
      "endpoints": [
        "https://github.com/contextuai/contextuai-solo/releases/latest/download/latest.json"
      ]
    }
  }
}
